{
  "name": "zer0gig-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for zer0Gig - Progressive Escrow & Agent Registry",
  "scripts": {
    "compile": "npx hardhat compile",
    "sync-abis": "node scripts/sync-abis.js",
    "compile:sync": "npx hardhat compile && node scripts/sync-abis.js",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js",
    "deploy:newton": "npx hardhat run scripts/deploy.js --network newton",
    "verify:newton": "npx hardhat run scripts/verify.js --network newton",
    "smoke:newton": "npx hardhat run scripts/smokeTest.js --network newton"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@openzeppelin/contracts": "^4.9.6",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.2"
  }
}
